# ── Groq API (free at https://console.groq.com) ──────────────────────────────
# Used for BOTH speech-to-text (Whisper) and LLM analysis (LLaMA 3.3 70B)
GROQ_API_KEY=gsk_...

# ── This service's API key (clients send this in the x-api-key header) ────────
CALL_ANALYTICS_API_KEY=your-secret-key-here

# ── Celery + Redis ────────────────────────────────────────────────────────────
# Set CELERY_TASK_ALWAYS_EAGER=true to skip Redis entirely (tasks run in-process).
# For production with a separate worker, set REDIS_URL and set EAGER to false.
CELERY_TASK_ALWAYS_EAGER=true
REDIS_URL=redis://localhost:6379/0

# ── Optional: comma-separated list of additional valid API keys ───────────────
# VALID_API_KEYS=key1,key2,key3